---
import BaseLayout from '../layouts/BaseLayout.astro';
import data from '../data/data.json';

const airItems     = data.filter((d) => d.transportMode === 'Air');
const surfaceItems = data.filter((d) => d.transportMode === 'Surface');
---

<BaseLayout
  title="Free Shipping Volumetric Weight Calculators — ShipCalc"
  description="Instantly calculate dimensional weight for Delhivery, BlueDart, FedEx, DHL, UPS and more. Free online calculators for Air and Surface couriers."
>
  <main class="mx-auto max-w-6xl px-4 py-16">

    <!-- Hero -->
    <div class="mb-16 text-center">
      <span class="mb-4 inline-flex items-center rounded-full border border-blue-500/20 bg-blue-500/10 px-4 py-1.5 text-sm font-medium text-blue-400">
        Free &middot; Instant &middot; No Signup
      </span>
      <h1 class="mt-4 text-4xl font-bold text-white md:text-5xl">
        Shipping Volumetric Weight<br />
        <span class="text-blue-400">Calculators</span>
      </h1>
      <p class="mx-auto mt-4 max-w-xl text-lg text-gray-400">
        Find your exact chargeable weight for every major courier. Stop overpaying on shipping fees.
      </p>
    </div>

    <!-- Air Calculators -->
    <section class="mb-12">
      <h2 class="mb-6 flex items-center gap-2 text-xl font-bold text-white">
        <span class="rounded-lg border border-purple-500/20 bg-purple-500/10 px-3 py-1 text-sm text-purple-400">✈ Air</span>
        Air Freight Calculators
      </h2>
      <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {airItems.map((item) => (
          <a
            href={`/calculator/${item.slug}`}
            class="group rounded-xl border border-gray-800 bg-gray-900 p-5 transition-all duration-200 hover:border-purple-500/40 hover:bg-gray-800"
          >
            <div class="mb-3 flex items-center justify-between">
              <span class="text-sm font-semibold text-white">{item.courierName}</span>
              <span class="rounded-full border border-purple-500/20 bg-purple-500/10 px-2 py-0.5 text-xs text-purple-400">Air</span>
            </div>
            <p class="mb-3 text-xs leading-relaxed text-gray-500 line-clamp-2">{item.metaDescription}</p>
            <div class="flex items-center justify-between">
              <span class="font-mono text-xs text-gray-600">÷ {item.divisor}</span>
              <span class="text-xs text-blue-400 transition-colors group-hover:text-blue-300">Calculate →</span>
            </div>
          </a>
        ))}
      </div>
    </section>

    <!-- Surface Calculators -->
    <section class="mb-16">
      <h2 class="mb-6 flex items-center gap-2 text-xl font-bold text-white">
        <span class="rounded-lg border border-green-500/20 bg-green-500/10 px-3 py-1 text-sm text-green-400">🚛 Surface</span>
        Surface / Ground Calculators
      </h2>
      <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {surfaceItems.map((item) => (
          <a
            href={`/calculator/${item.slug}`}
            class="group rounded-xl border border-gray-800 bg-gray-900 p-5 transition-all duration-200 hover:border-green-500/40 hover:bg-gray-800"
          >
            <div class="mb-3 flex items-center justify-between">
              <span class="text-sm font-semibold text-white">{item.courierName}</span>
              <span class="rounded-full border border-green-500/20 bg-green-500/10 px-2 py-0.5 text-xs text-green-400">Surface</span>
            </div>
            <p class="mb-3 text-xs leading-relaxed text-gray-500 line-clamp-2">{item.metaDescription}</p>
            <div class="flex items-center justify-between">
              <span class="font-mono text-xs text-gray-600">÷ {item.divisor}</span>
              <span class="text-xs text-blue-400 transition-colors group-hover:text-blue-300">Calculate →</span>
            </div>
          </a>
        ))}
      </div>
    </section>

    <!-- How it works -->
    <section class="rounded-2xl border border-gray-800 bg-gray-900 p-8 text-center">
      <h2 class="mb-2 text-xl font-bold text-white">How Volumetric Weight Works</h2>
      <p class="mb-8 text-gray-400">Couriers charge the higher of actual weight vs. dimensional weight.</p>
      <div class="mx-auto grid max-w-3xl grid-cols-1 gap-6 md:grid-cols-3">
        <div>
          <div class="mb-3 text-3xl">📦</div>
          <h3 class="mb-1 font-semibold text-white">Measure</h3>
          <p class="text-sm text-gray-500">Get the Length × Width × Height of your package in centimetres.</p>
        </div>
        <div>
          <div class="mb-3 text-3xl">➗</div>
          <h3 class="mb-1 font-semibold text-white">Divide</h3>
          <p class="text-sm text-gray-500">Divide the cubic volume by your courier's divisor (4000 or 5000).</p>
        </div>
        <div>
          <div class="mb-3 text-3xl">⚡</div>
          <h3 class="mb-1 font-semibold text-white">Compare</h3>
          <p class="text-sm text-gray-500">The higher of volumetric vs. actual weight is your billable weight.</p>
        </div>
      </div>
    </section>

  </main>
</BaseLayout>
