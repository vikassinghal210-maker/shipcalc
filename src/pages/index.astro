---
import BaseLayout from '../layouts/BaseLayout.astro';
import data from '../data/data.json';
import marketplace from '../data/marketplace.json';

const airItems     = data.filter((d) => d.transportMode === 'Air');
const surfaceItems = data.filter((d) => d.transportMode === 'Surface');

const amazonItems   = marketplace.filter((m) => m.platformName === 'Amazon India');
const flipkartItems = marketplace.filter((m) => m.platformName === 'Flipkart');
const meeshoItems   = marketplace.filter((m) => m.platformName === 'Meesho');
const otherItems    = marketplace.filter((m) => !['Amazon India', 'Flipkart', 'Meesho'].includes(m.platformName));

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'What is volumetric weight in shipping?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Volumetric weight (also called dimensional weight) is a pricing technique used by couriers to account for the space a package occupies. It is calculated by multiplying the length, width, and height of the package in centimetres and dividing by a courier-specific divisor (typically 4000 or 5000). The courier charges the higher of the volumetric weight or the actual physical weight.',
      },
    },
    {
      '@type': 'Question',
      name: 'What is the difference between a 4000 and 5000 divisor?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'A divisor of 4000 is typically used for surface (ground) shipments, while 5000 is standard for air express shipments in India. A lower divisor means the volumetric weight will be higher for the same package size, making surface shipments relatively more expensive for bulky lightweight parcels compared to air shipments.',
      },
    },
    {
      '@type': 'Question',
      name: 'Which Indian couriers use a 4000 divisor?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Most Indian couriers use a divisor of 4000 for surface shipments, including Delhivery, BlueDart, DTDC, Xpressbees, Ekart Logistics, Ecom Express, Shiprocket, and Gati KWE. This is the standard domestic ground freight divisor across India.',
      },
    },
    {
      '@type': 'Question',
      name: 'How do I calculate chargeable weight for a shipment?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'To calculate chargeable weight: (1) Measure your package dimensions in centimetres. (2) Multiply Length × Width × Height to get the cubic volume. (3) Divide by your courier\'s divisor (e.g. 5000 for air, 4000 for surface) to get the volumetric weight. (4) Compare with the actual dead weight of the package. The higher of the two is your chargeable (billable) weight.',
      },
    },
    {
      '@type': 'Question',
      name: 'Why does FedEx use a 5000 divisor for ground shipments?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'FedEx Ground uses a divisor of 5000 cm³/kg (equivalent to 139 cubic inches per pound in imperial units) for its ground shipments. This is higher than the 4000 divisor used by most Indian couriers, making FedEx Ground relatively more forgiving for bulky lightweight packages compared to Indian surface couriers.',
      },
    },
    {
      '@type': 'Question',
      name: 'What divisor does India Post Speed Post use?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'India Post Speed Post and EMS international shipments use the IATA standard divisor of 6000 cm³/kg, which is higher than the 5000 used by private express couriers. This makes India Post a cost-effective option for dense, heavy parcels where actual weight consistently exceeds volumetric weight.',
      },
    },
  ],
};
---

<BaseLayout
  title="Free Shipping Volumetric Weight Calculators — ShipCalc"
  description="Instantly calculate dimensional weight for Delhivery, BlueDart, FedEx, DHL, UPS and more. Free online calculators for Air and Surface couriers."
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  </Fragment>

  <main class="mx-auto max-w-6xl px-4 py-16">

    <!-- Hero -->
    <div class="mb-16 text-center">
      <span class="mb-4 inline-flex items-center rounded-full border border-blue-500/20 bg-blue-500/10 px-4 py-1.5 text-sm font-medium text-blue-400">
        Free &middot; Instant &middot; No Signup
      </span>
      <h1 class="mt-4 text-4xl font-bold text-white md:text-5xl">
        Shipping Volumetric Weight<br />
        <span class="text-blue-400">Calculators</span>
      </h1>
      <p class="mx-auto mt-4 max-w-xl text-lg text-gray-400">
        Find your exact chargeable weight for every major courier. Stop overpaying on shipping fees.
      </p>
    </div>

    <!-- Air Calculators -->
    <section class="mb-12">
      <h2 class="mb-6 flex items-center gap-2 text-xl font-bold text-white">
        <span class="rounded-lg border border-purple-500/20 bg-purple-500/10 px-3 py-1 text-sm text-purple-400">✈ Air</span>
        Air Freight Calculators
      </h2>
      <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {airItems.map((item) => (
          <a
            href={`/calculator/${item.slug}`}
            class="group rounded-xl border border-gray-800 bg-gray-900 p-5 transition-all duration-200 hover:border-purple-500/40 hover:bg-gray-800"
          >
            <div class="mb-3 flex items-center justify-between">
              <span class="text-sm font-semibold text-white">{item.courierName}</span>
              <span class="rounded-full border border-purple-500/20 bg-purple-500/10 px-2 py-0.5 text-xs text-purple-400">Air</span>
            </div>
            <p class="mb-3 text-xs leading-relaxed text-gray-500 line-clamp-2">{item.metaDescription}</p>
            <div class="flex items-center justify-between">
              <span class="font-mono text-xs text-gray-600">÷ {item.divisor}</span>
              <span class="text-xs text-blue-400 transition-colors group-hover:text-blue-300">Calculate →</span>
            </div>
          </a>
        ))}
      </div>
    </section>

    <!-- Surface Calculators -->
    <section class="mb-16">
      <h2 class="mb-6 flex items-center gap-2 text-xl font-bold text-white">
        <span class="rounded-lg border border-green-500/20 bg-green-500/10 px-3 py-1 text-sm text-green-400">🚛 Surface</span>
        Surface / Ground Calculators
      </h2>
      <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {surfaceItems.map((item) => (
          <a
            href={`/calculator/${item.slug}`}
            class="group rounded-xl border border-gray-800 bg-gray-900 p-5 transition-all duration-200 hover:border-green-500/40 hover:bg-gray-800"
          >
            <div class="mb-3 flex items-center justify-between">
              <span class="text-sm font-semibold text-white">{item.courierName}</span>
              <span class="rounded-full border border-green-500/20 bg-green-500/10 px-2 py-0.5 text-xs text-green-400">Surface</span>
            </div>
            <p class="mb-3 text-xs leading-relaxed text-gray-500 line-clamp-2">{item.metaDescription}</p>
            <div class="flex items-center justify-between">
              <span class="font-mono text-xs text-gray-600">÷ {item.divisor}</span>
              <span class="text-xs text-blue-400 transition-colors group-hover:text-blue-300">Calculate →</span>
            </div>
          </a>
        ))}
      </div>
    </section>

    <!-- How it works -->
    <section class="mb-16 rounded-2xl border border-gray-800 bg-gray-900 p-8 text-center">
      <h2 class="mb-2 text-xl font-bold text-white">How Volumetric Weight Works</h2>
      <p class="mb-8 text-gray-400">Couriers charge the higher of actual weight vs. dimensional weight.</p>
      <div class="mx-auto grid max-w-3xl grid-cols-1 gap-6 md:grid-cols-3">
        <div>
          <div class="mb-3 text-3xl">📦</div>
          <h3 class="mb-1 font-semibold text-white">Measure</h3>
          <p class="text-sm text-gray-500">Get the Length × Width × Height of your package in centimetres.</p>
        </div>
        <div>
          <div class="mb-3 text-3xl">➗</div>
          <h3 class="mb-1 font-semibold text-white">Divide</h3>
          <p class="text-sm text-gray-500">Divide the cubic volume by your courier's divisor (4000, 5000, or 6000).</p>
        </div>
        <div>
          <div class="mb-3 text-3xl">⚡</div>
          <h3 class="mb-1 font-semibold text-white">Compare</h3>
          <p class="text-sm text-gray-500">The higher of volumetric vs. actual weight is your billable weight.</p>
        </div>
      </div>
    </section>

    <!-- Marketplace Fee Calculators -->
    <section class="mb-16" id="marketplace">
      <div class="mb-8 text-center">
        <h2 class="text-2xl font-bold text-white">Marketplace Seller Fee Calculators</h2>
        <p class="mt-2 text-gray-400">Find your exact net payout after platform fees for Amazon, Flipkart, Myntra & Nykaa.</p>
      </div>

      <!-- Amazon India -->
      <div class="mb-8">
        <h3 class="mb-4 flex items-center gap-2 text-lg font-bold text-white">
          <span class="rounded-lg border border-orange-500/20 bg-orange-500/10 px-3 py-1 text-sm text-orange-400">📦 Amazon India</span>
        </h3>
        <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3">
          {amazonItems.map((item) => (
            <a href={`/fees/${item.slug}`}
              class="group rounded-xl border border-gray-800 bg-gray-900 p-5 transition-all duration-200 hover:border-orange-500/40 hover:bg-gray-800">
              <div class="mb-3 flex items-center justify-between">
                <span class="text-sm font-semibold text-white">{item.category}</span>
                <span class="rounded-full border border-orange-500/20 bg-orange-500/10 px-2 py-0.5 text-xs text-orange-400">{item.referralFeePercent}%</span>
              </div>
              <p class="mb-3 text-xs leading-relaxed text-gray-500 line-clamp-2">{item.metaDescription}</p>
              <span class="text-xs text-blue-400 transition-colors group-hover:text-blue-300">Calculate →</span>
            </a>
          ))}
        </div>
      </div>

      <!-- Flipkart -->
      <div class="mb-8">
        <h3 class="mb-4 flex items-center gap-2 text-lg font-bold text-white">
          <span class="rounded-lg border border-blue-500/20 bg-blue-500/10 px-3 py-1 text-sm text-blue-400">🛒 Flipkart</span>
        </h3>
        <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3">
          {flipkartItems.map((item) => (
            <a href={`/fees/${item.slug}`}
              class="group rounded-xl border border-gray-800 bg-gray-900 p-5 transition-all duration-200 hover:border-blue-500/40 hover:bg-gray-800">
              <div class="mb-3 flex items-center justify-between">
                <span class="text-sm font-semibold text-white">{item.category}</span>
                <span class="rounded-full border border-blue-500/20 bg-blue-500/10 px-2 py-0.5 text-xs text-blue-400">{item.referralFeePercent}%</span>
              </div>
              <p class="mb-3 text-xs leading-relaxed text-gray-500 line-clamp-2">{item.metaDescription}</p>
              <span class="text-xs text-blue-400 transition-colors group-hover:text-blue-300">Calculate →</span>
            </a>
          ))}
        </div>
      </div>

      <!-- Meesho -->
      <div class="mb-8">
        <h3 class="mb-4 flex items-center gap-2 text-lg font-bold text-white">
          <span class="rounded-lg border border-green-500/20 bg-green-500/10 px-3 py-1 text-sm text-green-400">🎉 Meesho — 0% Commission</span>
        </h3>
        <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3">
          {meeshoItems.map((item) => (
            <a href={`/fees/${item.slug}`}
              class="group rounded-xl border border-gray-800 bg-gray-900 p-5 transition-all duration-200 hover:border-green-500/40 hover:bg-gray-800">
              <div class="mb-3 flex items-center justify-between">
                <span class="text-sm font-semibold text-white">{item.category}</span>
                <span class="rounded-full border border-green-500/20 bg-green-500/10 px-2 py-0.5 text-xs font-bold text-green-400">0%</span>
              </div>
              <p class="mb-3 text-xs leading-relaxed text-gray-500 line-clamp-2">{item.metaDescription}</p>
              <span class="text-xs text-blue-400 transition-colors group-hover:text-blue-300">Calculate →</span>
            </a>
          ))}
        </div>
      </div>

      <!-- Myntra & Nykaa -->
      <div>
        <h3 class="mb-4 flex items-center gap-2 text-lg font-bold text-white">
          <span class="rounded-lg border border-pink-500/20 bg-pink-500/10 px-3 py-1 text-sm text-pink-400">✨ Fashion & Beauty</span>
        </h3>
        <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3">
          {otherItems.map((item) => (
            <a href={`/fees/${item.slug}`}
              class="group rounded-xl border border-gray-800 bg-gray-900 p-5 transition-all duration-200 hover:border-pink-500/40 hover:bg-gray-800">
              <div class="mb-3 flex items-center justify-between">
                <span class="text-sm font-semibold text-white">{item.platformName}</span>
                <span class="rounded-full border border-pink-500/20 bg-pink-500/10 px-2 py-0.5 text-xs text-pink-400">{item.referralFeePercent}%</span>
              </div>
              <p class="mb-1 text-xs text-gray-500">{item.category}</p>
              <p class="mb-3 text-xs leading-relaxed text-gray-600 line-clamp-2">{item.metaDescription}</p>
              <span class="text-xs text-blue-400 transition-colors group-hover:text-blue-300">Calculate →</span>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- Blog -->
    <section class="mb-16">
      <h2 class="mb-6 text-xl font-bold text-white">Shipping Resources</h2>
      <div class="space-y-4">
      <a
        href="/blog/what-is-volumetric-weight"
        class="group flex items-center justify-between rounded-xl border border-gray-800 bg-gray-900 p-6 transition-all duration-200 hover:border-blue-500/40 hover:bg-gray-800"
      >
        <div>
          <span class="mb-2 inline-block rounded-full border border-blue-500/20 bg-blue-500/10 px-2 py-0.5 text-xs text-blue-400">Guide</span>
          <h3 class="mt-1 font-semibold text-white">What is Volumetric Weight in Shipping? A Complete Guide</h3>
          <p class="mt-1 text-sm text-gray-500">Learn the formula, courier divisors, and 5 tips to reduce your shipping costs.</p>
        </div>
        <span class="ml-6 shrink-0 text-blue-400 transition-colors group-hover:text-blue-300">Read →</span>
      </a>
      <a
        href="/blog/amazon-vs-flipkart-seller-fees"
        class="group flex items-center justify-between rounded-xl border border-gray-800 bg-gray-900 p-6 transition-all duration-200 hover:border-orange-500/40 hover:bg-gray-800"
      >
        <div>
          <span class="mb-2 inline-block rounded-full border border-orange-500/20 bg-orange-500/10 px-2 py-0.5 text-xs text-orange-400">Comparison</span>
          <h3 class="mt-1 font-semibold text-white">Amazon India vs Flipkart Seller Fees: Complete Comparison 2025</h3>
          <p class="mt-1 text-sm text-gray-500">Category-by-category fee breakdown to help you pick the right platform.</p>
        </div>
        <span class="ml-6 shrink-0 text-blue-400 transition-colors group-hover:text-blue-300">Read →</span>
      </a>
      </div>
    </section>

    <!-- FAQ Section -->
    <section class="mb-8">
      <h2 class="mb-8 text-center text-2xl font-bold text-white">
        Frequently Asked Questions
      </h2>
      <div class="mx-auto max-w-3xl space-y-4">
        {faqSchema.mainEntity.map((faq) => (
          <details class="group rounded-xl border border-gray-800 bg-gray-900 p-5">
            <summary class="flex cursor-pointer items-center justify-between font-medium text-white">
              {faq.name}
              <span class="ml-4 shrink-0 text-gray-500 transition-transform group-open:rotate-180">▼</span>
            </summary>
            <p class="mt-3 text-sm leading-relaxed text-gray-400">
              {faq.acceptedAnswer.text}
            </p>
          </details>
        ))}
      </div>
    </section>

  </main>
</BaseLayout>
